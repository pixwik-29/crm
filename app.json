{
  "expo": {
    "name": "PS-CRM",
    "slug": "crm",
    "version": "1.0.1",
    "orientation": "portrait",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/13d4d5f3-78e7-444f-9e40-fcfdc281b17e",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.perfectscholar.crm",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "PS-CRM needs access to your camera to capture lead documents.",
        "NSPhotoLibraryUsageDescription": "PS-CRM needs access to your gallery to upload lead documents."
      }
    },
    "android": {
      "package": "com.perfectscholar.crm",
      "googleServicesFile": "./google-services.json",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "13d4d5f3-78e7-444f-9e40-fcfdc281b17e"
      }
    },
    "owner": "nashnewton",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "targetSdkVersion": 36,
            "compileSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PS-CRM needs access to your gallery to upload lead documents.",
          "cameraPermission": "PS-CRM needs access to your camera to capture lead documents.",
          "microphonePermission": false
        }
      ],
      "expo-updates"
    ]
  }
}
